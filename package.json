{
  "name": "vprequisicoes",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:types": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:M1": "vitest run --dir packages/modules/M1-products/__tests__",
    "test:approval": "vitest run --dir packages/modules/approval/__tests__",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:workflow": "vitest run --dir packages/core/workflow/__tests__",
    "test:all": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.10.2",
    "@tanstack/react-query": "^5.24.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.50.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.1",
    "xstate": "^5.6.2",
    "zod": "^3.22.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.3.0",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitest/coverage-v8": "^1.2.0",
    "autoprefixer": "^10.4.18",
    "jsdom": "^23.0.0",
    "postcss": "^8.4.35",
    "prisma": "^5.10.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "@playwright/test": "^1.44.0"
  }
}
